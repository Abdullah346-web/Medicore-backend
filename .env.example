NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai-clinic-saas
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# AI provider is optional. If omitted, server auto-uses OPENAI_API_KEY or GEMINI_API_KEY if present.
AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=ai-clinic/prescriptions

# Revenue simulation for admin analytics
SIMULATED_ARPU=30
